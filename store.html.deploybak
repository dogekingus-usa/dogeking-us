<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

<style>
:root {
    --primary: #f59e0b;
    --primary-dark: #d97706;
    --primary-light: #fbbf24;
    --secondary: #8b5cf6;
    --bg: #0a0a1a;
    --surface: #1a1a2e;
    --surface2: #2a2a4e;
    --text: #f1f5f9;
    --text-muted: #94a3b8;
    --heading-font: 'Inter', sans-serif;
    --body-font: 'Inter', sans-serif;
    --gradient: linear-gradient(135deg, #f59e0b, #fbbf24);
}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:var(--body-font);background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden}
header{background:linear-gradient(135deg, #0a0a1a 0%, #1a1a2e 40%, #f59e0b 100%);padding:70px 20px 40px;text-align:center;border-bottom:1px solid rgba(255,255,255,0.08);position:relative}
header::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:var(--gradient);opacity:0.3}
header h1{font-family:var(--heading-font);font-size:2.8em;font-weight:700;background:var(--gradient);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:12px}
header p{color:var(--text-muted);font-size:1.05em;max-width:600px;margin:0 auto;line-height:1.7}
.container{max-width:1100px;margin:0 auto;padding:30px 20px 60px}
.store-header{text-align:center;margin-bottom:40px}
.store-header h2{font-family:var(--heading-font);font-size:1.8em;margin-bottom:8px}
.store-header p{color:var(--text-muted);font-size:0.95em}
.products-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:24px;margin-bottom:50px}
.product-card{background:var(--surface);border-radius:16px;padding:28px;border:1px solid rgba(255,255,255,0.06);position:relative;transition:all 0.3s ease;display:flex;flex-direction:column}
.product-card:hover{transform:translateY(-4px);border-color:var(--primary);box-shadow:0 12px 40px rgba(var(--primary),0.15)}
.product-badge{position:absolute;top:16px;right:16px;background:var(--gradient);color:#fff;font-size:0.7em;font-weight:600;padding:4px 12px;border-radius:20px;letter-spacing:0.5px;text-transform:uppercase}
.product-card h3{font-family:var(--heading-font);font-size:1.15em;margin-bottom:12px;color:#fff}
.product-desc{color:var(--text-muted);font-size:0.9em;line-height:1.6;margin-bottom:16px}
.product-features{list-style:none;padding:0;margin:0 0 20px;flex:1}
.product-features li{padding:6px 0;font-size:0.85em;color:var(--text-muted);border-bottom:1px solid rgba(255,255,255,0.04)}
.product-footer{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-top:auto;padding-top:16px;border-top:1px solid rgba(255,255,255,0.06)}
.product-price{font-family:'JetBrains Mono',monospace;font-size:1.4em;font-weight:700;color:var(--primary)}
.buy-btn{display:inline-block;background:var(--gradient);color:#fff;padding:10px 20px;border-radius:8px;text-decoration:none;font-weight:600;font-size:0.85em;transition:all 0.2s ease;white-space:nowrap}
.buy-btn:hover{transform:translateY(-2px);box-shadow:0 4px 15px rgba(0,0,0,0.3);filter:brightness(1.1)}
.bundle-section{margin:50px 0}
.bundle-card{background:linear-gradient(135deg,var(--surface),var(--surface2));border:2px solid var(--secondary);border-radius:20px;padding:36px;text-align:center;position:relative}
.bundle-badge{display:inline-block;background:var(--secondary);color:#000;font-size:0.8em;font-weight:700;padding:6px 20px;border-radius:20px;margin-bottom:16px;text-transform:uppercase;letter-spacing:1px}
.bundle-card h2{font-family:var(--heading-font);font-size:1.5em;margin-bottom:12px}
.bundle-card p{color:var(--text-muted);font-size:0.95em;line-height:1.6;max-width:500px;margin:0 auto 20px}
.bundle-footer{display:flex;align-items:center;justify-content:center;gap:20px}
.bundle-price{font-family:'JetBrains Mono',monospace;font-size:2em;font-weight:700;color:var(--secondary)}
.bundle-btn{padding:14px 28px;font-size:1em}
.nav-bar{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(12,10,29,0.8);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);border-bottom:1px solid rgba(255,255,255,0.06);padding:12px 24px;display:flex;align-items:center;justify-content:space-between}
.nav-bar .logo{font-family:var(--heading-font);font-weight:700;font-size:1.1em;color:#fff;text-decoration:none}
.nav-bar .logo span{color:var(--primary)}
.nav-links{display:flex;gap:16px;align-items:center}
.nav-links a{color:var(--text-muted);text-decoration:none;font-size:0.85em;font-weight:500;transition:color 0.2s}
.nav-links a:hover{color:#fff}
.nav-links a.active{color:var(--primary)}
.footer{text-align:center;padding:40px 20px;color:#555;font-size:0.8em;border-top:1px solid rgba(255,255,255,0.04)}
@media(max-width:600px){
    header h1{font-size:1.8em}
    .products-grid{grid-template-columns:1fr}
    .bundle-footer{flex-direction:column;gap:12px}
    .nav-links{gap:10px}
    .nav-links a{font-size:0.75em}
}

    /* ===== SITE-WIDE NAV & FOOTER COMPONENTS ===== */
    :root {
      --nav-height: 64px;
      --nav-bg: rgba(11, 15, 26, 0.88);
      --footer-bg: #0a0d16;
      --footer-border: rgba(255,255,255,0.06);
    }
    nav#site-nav {
      position: fixed; top: 0; left: 0; right: 0; height: var(--nav-height); z-index: 1000;
      background: var(--nav-bg);
      backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--glass-border, rgba(79,70,229,0.15));
      animation: navSlideDown 0.5s ease-out;
    }
    @keyframes navSlideDown {
      from { transform: translateY(-100%); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }
    .nav-inner {
      max-width: var(--container-max, 1280px); margin: 0 auto; padding: 0 var(--container-padding, 1rem);
      height: 100%; display: flex; align-items: center; justify-content: space-between;
    }
    .nav-logo {
      display: flex; align-items: center; gap: 0.5rem;
      font-weight: 700; font-size: 1.2rem; color: var(--color-text, #f1f5f9); text-decoration: none;
    }
    .nav-logo span { background: linear-gradient(135deg, var(--color-primary, #4f46e5), var(--color-primary-light, #6366f1)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .nav-logo .gold { background: none; -webkit-text-fill-color: var(--gold, #d4a017); }
    .nav-links { display: flex; align-items: center; gap: 1.5rem; }
    .nav-links a { color: #94a3b8; font-size: 0.875rem; font-weight: 500; text-decoration: none; transition: color 0.3s; position: relative; }
    .nav-links a::after { content: ''; position: absolute; bottom: -4px; left: 0; width: 0; height: 2px; background: linear-gradient(90deg, var(--color-primary, #4f46e5), var(--color-primary-light, #6366f1)); transition: width 0.3s; }
    .nav-links a:hover::after, .nav-links a.active::after { width: 100%; }
    .nav-links a:hover, .nav-links a.active { color: #e2e8f0; }
    .hamburger { display: none; background: none; border: 1px solid rgba(255,255,255,0.15); color: #94a3b8; width: 36px; height: 36px; border-radius: 8px; cursor: pointer; flex-direction: column; align-items: center; justify-content: center; gap: 4px; transition: all 0.3s; }
    .hamburger:hover { border-color: var(--color-primary, #4f46e5); }
    .hamburger span { display: block; width: 18px; height: 2px; background: #94a3b8; border-radius: 2px; transition: all 0.3s; }

    /* ===== FOOTER ===== */
    footer {
      padding: 3rem 0 1.5rem;
      border-top: 1px solid var(--footer-border);
      background: var(--footer-bg);
    }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 2rem; margin-bottom: 2rem; }
    .footer-brand h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.75rem; color: var(--color-text, #f1f5f9); }
    .footer-brand h3 span { background: linear-gradient(135deg, var(--color-primary, #4f46e5), var(--color-primary-light, #6366f1)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .footer-brand .gold { background: none; -webkit-text-fill-color: var(--gold, #d4a017); }
    .footer-brand p { font-size: 0.813rem; color: #64748b; line-height: 1.6; }
    .footer-col h4 { font-size: 0.813rem; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1rem; }
    .footer-col a { display: block; font-size: 0.875rem; color: #64748b; margin-bottom: 0.5rem; transition: color 0.3s; text-decoration: none; }
    .footer-col a:hover { color: var(--color-primary-light, #6366f1); }
    .footer-bottom { border-top: 1px solid var(--footer-border); padding-top: 1.5rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 0.5rem; }
    .footer-bottom p { font-size: 0.75rem; color: #475569; }

    /* ===== MOBILE NAV ===== */
    @media (max-width: 768px) {
      .nav-links { display: none; position: fixed; top: var(--nav-height); left: 0; right: 0; background: rgba(11,15,26,0.98); backdrop-filter: blur(20px); flex-direction: column; padding: 1rem; gap: 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.06); }
      .nav-links.mobile-open { display: flex; }
      .nav-links a { padding: 0.75rem 1rem; border-radius: 8px; width: 100%; }
      .nav-links a:hover { background: rgba(255,255,255,0.05); }
      .hamburger { display: flex; }
      .footer-grid { grid-template-columns: 1fr 1fr; }
      .footer-grid > :first-child { grid-column: 1 / -1; }
      .footer-bottom { flex-direction: column; text-align: center; }
    }
    @media (max-width: 480px) {
      .footer-grid { grid-template-columns: 1fr; }
    }

    /* SPACING FOR ARTICLES (offset for fixed nav) */
    body { padding-top: var(--nav-height); }
</style>
