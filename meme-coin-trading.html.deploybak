    background: linear-gradient(135deg, #0a0a1a 0%, #1a1040 40%, #0d0d2b 100%);
    display: flex; flex-direction: column; justify-content: center; align-items: center;
    position: relative;
  }
  .accent-stripe { position: absolute; left: 0; top: 0; width: 12px; height: 100%; background: linear-gradient(180deg, #FF6B6B 0%, #FF4500 50%, #DC143C 100%); box-shadow: 2px 0 20px rgba(255, 107, 107, 0.3); }
  .corner-tl, .corner-br { position: absolute; width: 60px; height: 60px; border-color: rgba(255, 107, 107, 0.15); border-style: solid; }
  .corner-tl { top: 20px; left: 20px; border-width: 2px 0 0 2px; }
  .corner-br { bottom: 20px; right: 20px; border-width: 0 2px 2px 0; }
  .watermark { position: absolute; right: 30px; bottom: 120px; font-size: 140px; opacity: 0.04; color: #FF6B6B; user-select: none; }
  .grid-bg { position: absolute; inset: 0; background-image: linear-gradient(rgba(255, 107, 107, 0.02) 1px, transparent 1px), linear-gradient(90deg, rgba(255, 107, 107, 0.02) 1px, transparent 1px); background-size: 40px 40px; }
  .glow-1 { position: absolute; width: 350px; height: 350px; border-radius: 50%; background: radial-gradient(circle, rgba(255, 107, 107, 0.08) 0%, transparent 70%); top: -120px; right: -100px; }
  .glow-2 { position: absolute; width: 250px; height: 250px; border-radius: 50%; background: radial-gradient(circle, rgba(147, 51, 234, 0.1) 0%, transparent 70%); bottom: -80px; left: -80px; }
  .brand { position: absolute; top: 30px; left: 30px; display: flex; align-items: center; gap: 10px; }
  .brand-icon { font-size: 36px; line-height: 1; }
  .brand-text { font-family: 'Playfair Display', serif; font-size: 24px; font-weight: 700; color: #FF6B6B; letter-spacing: 0.5px; }
  .brand-text span { color: rgba(255,255,255,0.4); font-weight: 400; font-size: 17px; margin-left: 6px; }
  .tag { display: inline-block; padding: 6px 16px; background: rgba(255, 107, 107, 0.12); border: 1px solid rgba(255, 107, 107, 0.3); border-radius: 20px; font-family: 'Inter', 'Arial', sans-serif; font-size: 13px; color: #FF6B6B; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 20px; }
  .main-title { font-size: 52px; font-weight: 700; color: #FFFFFF; line-height: 1.15; text-shadow: 0 2px 30px rgba(0,0,0,0.5); margin-bottom: 8px; text-align: center; max-width: 900px; padding: 0 40px; }
  .main-title .gold { color: #FF6B6B; }
  .subtitle { font-family: 'Inter', 'Arial', sans-serif; font-size: 15px; color: rgba(255,255,255,0.4); letter-spacing: 3px; text-transform: uppercase; font-weight: 300; margin-top: 6px; }
  .divider { width: 80px; height: 2px; background: linear-gradient(90deg, transparent, #FF6B6B, transparent); margin: 14px auto; opacity: 0.5; }
  .url-bar { position: absolute; bottom: 28px; left: 0; right: 0; text-align: center; font-family: 'Inter', 'Arial', sans-serif; font-size: 13px; color: rgba(255,255,255,0.3); letter-spacing: 3px; text-transform: uppercase; }
</style>
