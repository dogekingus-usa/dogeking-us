<style>


:root {


  --color-gold: #F59E0B;


  --color-gold-dim: #d4a508;


  --crypto-green: #10B981;


  --crypto-green-dim: #059669;


  --bg-primary: #0a0a1a;


  --bg-secondary: #0f0f2a;


  --card-bg: rgba(255, 255, 255, 0.04);


  --card-border: rgba(255, 255, 255, 0.08);


  --card-hover: rgba(255, 255, 255, 0.07);


  --text-primary: #e8e8f0;


  --text-secondary: rgba(255, 255, 255, 0.6);


  --text-muted: rgba(255, 255, 255, 0.4);


  --danger: #EF4444;


  --warning: #F59E0B;


  --success: #10B981;


  --info: #3B82F6;


  --radius: 12px;


  --radius-sm: 8px;


  --glow-gold: 0 0 20px rgba(245, 158, 11, 0.15);


  --glow-green: 0 0 20px rgba(16, 185, 129, 0.15);


}





* { margin: 0; padding: 0; box-sizing: border-box; }





body {


  font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;


  background: var(--bg-primary);


  color: var(--text-primary);


  line-height: 1.8;


  padding: 20px;


  min-height: 100vh;


  position: relative;


}





body::before {


  content: '';


  position: fixed;


  top: 0;


  left: 0;


  width: 100%;


  height: 100%;


  background:


    radial-gradient(ellipse at 20% 10%, rgba(245, 158, 11, 0.04) 0%, transparent 50%),


    radial-gradient(ellipse at 80% 90%, rgba(16, 185, 129, 0.04) 0%, transparent 50%),


    radial-gradient(ellipse at 50% 50%, rgba(59, 130, 246, 0.02) 0%, transparent 50%);


  pointer-events: none;


  z-index: 0;


}





article, .container {


  max-width: 820px;


  margin: 0 auto;


  position: relative;


  z-index: 1;


}





/* Glass Card Component */


.glass-card {


  background: var(--card-bg);


  border: 1px solid var(--card-border);


  border-radius: var(--radius);


  padding: 24px;


  margin: 24px 0;


  backdrop-filter: blur(12px);


  -webkit-backdrop-filter: blur(12px);


  transition: all 0.3s ease;


}





.glass-card:hover {


  background: var(--card-hover);


  border-color: rgba(255, 255, 255, 0.12);


}





.glass-card.gold-glow {


  box-shadow: var(--glow-gold);


}





.glass-card.green-glow {


  box-shadow: var(--glow-green);


}





/* Breadcrumb */


.breadcrumb {


  display: flex;


  align-items: center;


  gap: 8px;


  font-size: 0.85rem;


  color: var(--text-muted);


  margin: 16px 0 0;


  padding: 0;


  flex-wrap: wrap;


}





.breadcrumb a {


  color: var(--color-gold);


  text-decoration: none;


  border-bottom: 1px solid transparent;


  transition: border-color 0.2s;


}





.breadcrumb a:hover {


  border-bottom-color: var(--color-gold);


}





.back-link {


  display: inline-block;


  margin: 8px 0 24px;


  color: var(--color-gold);


  font-weight: 500;


  text-decoration: none;


  font-size: 0.9rem;


  border-bottom: 1px solid transparent;


  transition: border-color 0.2s;


}





.back-link:hover {


  border-bottom-color: var(--color-gold);


}





/* Tags */


.tag {


  display: inline-block;


  padding: 6px 16px;


  background: rgba(245, 158, 11, 0.08);


  border: 1px solid rgba(245, 158, 11, 0.2);


  border-radius: 50px;


  font-size: 0.75rem;


  color: var(--color-gold);


  font-weight: 600;


  margin-bottom: 16px;


  text-transform: uppercase;


  letter-spacing: 0.5px;


}





.tag.green {


  background: rgba(16, 185, 129, 0.08);


  border-color: rgba(16, 185, 129, 0.2);


  color: var(--crypto-green);


}





.tag.blue {


  background: rgba(59, 130, 246, 0.08);


  border-color: rgba(59, 130, 246, 0.2);


  color: var(--info);


}





.tag.red {


  background: rgba(239, 68, 68, 0.08);


  border-color: rgba(239, 68, 68, 0.2);


  color: var(--danger);


}





/* Headings */


h1 {


  color: var(--color-gold);


  font-size: 2.4em;


  font-weight: 800;


  margin: 0 0 16px;


  line-height: 1.2;


  letter-spacing: -0.5px;


}





h2 {


  color: var(--color-gold);


  font-size: 1.5em;


  font-weight: 700;


  margin: 48px 0 16px;


  padding-bottom: 10px;


  border-bottom: 1px solid rgba(245, 158, 11, 0.12);


  line-height: 1.3;


}





h2 .emoji, h2 i {


  margin-right: 8px;


}





h3 {


  color: var(--crypto-green);


  font-size: 1.2em;


  font-weight: 600;


  margin: 32px 0 12px;


  line-height: 1.4;


}





/* Paragraphs & Links */


p {


  margin: 0 0 20px;


  color: var(--text-secondary);


  font-size: 1.05rem;


  line-height: 1.8;


}





a {


  color: var(--color-gold);


  text-decoration: none;


  border-bottom: 1px solid transparent;


  transition: border-color 0.2s, color 0.2s;


}





a:hover {


  border-bottom-color: var(--color-gold);


  color: #fbbf24;


}





strong {


  color: var(--text-primary);


  font-weight: 600;


}





/* Lists */


ul, ol {


  margin: 0 0 20px;


  padding-left: 24px;


  color: var(--text-secondary);


  line-height: 1.8;


}





li {


  margin-bottom: 8px;


}





li strong {


  color: var(--text-primary);


}





/* Blockquotes / Highlight Boxes */


.highlight-box {


  background: rgba(245, 158, 11, 0.06);


  border-left: 4px solid var(--color-gold);


  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;


  padding: 20px 24px;


  margin: 24px 0;


}





.highlight-box.green {


  border-left-color: var(--crypto-green);


  background: rgba(16, 185, 129, 0.06);


}





.highlight-box.red {


  border-left-color: var(--danger);


  background: rgba(239, 68, 68, 0.06);


}





.highlight-box.blue {


  border-left-color: var(--info);


  background: rgba(59, 130, 246, 0.06);


}





.highlight-box p {


  margin: 0;


  font-size: 0.95rem;


}





.highlight-box .title {


  font-weight: 700;


  color: var(--color-gold);


  margin-bottom: 8px;


  display: block;


}





.highlight-box.green .title { color: var(--crypto-green); }


.highlight-box.red .title { color: var(--danger); }


.highlight-box.blue .title { color: var(--info); }





/* Tables */


.table-wrapper {


  overflow-x: auto;


  margin: 24px 0;


  border-radius: var(--radius);


  background: var(--card-bg);


  border: 1px solid var(--card-border);


  backdrop-filter: blur(12px);


  -webkit-backdrop-filter: blur(12px);


}





table {


  width: 100%;


  border-collapse: collapse;


  font-size: 0.9rem;


}





thead th {


  background: rgba(245, 158, 11, 0.08);


  color: var(--color-gold);


  padding: 14px 16px;


  text-align: left;


  font-weight: 600;


  font-size: 0.85rem;


  text-transform: uppercase;


  letter-spacing: 0.5px;


  border-bottom: 1px solid rgba(245, 158, 11, 0.15);


}





tbody td {


  padding: 12px 16px;


  border-bottom: 1px solid rgba(255, 255, 255, 0.04);


  color: var(--text-secondary);


}





tbody tr:last-child td {


  border-bottom: none;


}





tbody tr:hover {


  background: rgba(255, 255, 255, 0.03);


}





td:first-child {


  color: var(--text-primary);


  font-weight: 500;


}





/* Checklist */


.checklist {


  list-style: none;


  padding: 0;


  margin: 16px 0;


}





.checklist li {


  position: relative;


  padding: 10px 0 10px 36px;


  margin: 0;


  color: var(--text-secondary);


  border-bottom: 1px solid rgba(255, 255, 255, 0.04);


}





.checklist li:last-child {


  border-bottom: none;


}





.checklist li::before {


  content: 'âËœÂ';


  position: absolute;


  left: 0;


  top: 10px;


  font-size: 1.2rem;


  color: var(--color-gold);


}





.checklist li.completed::before {


  content: 'âËœ”˜';


  color: var(--crypto-green);


}





.checklist li .label {


  display: inline-block;


  padding: 2px 8px;


  border-radius: 4px;


  font-size: 0.7rem;


  font-weight: 600;


  text-transform: uppercase;


  letter-spacing: 0.3px;


  margin-right: 6px;


}





.label.gold { background: rgba(245, 158, 11, 0.15); color: var(--color-gold); }


.label.green { background: rgba(16, 185, 129, 0.15); color: var(--crypto-green); }


.label.red { background: rgba(239, 68, 68, 0.15); color: var(--danger); }


.label.blue { background: rgba(59, 130, 246, 0.15); color: var(--info); }





/* Step Plan */


.step-plan {


  counter-reset: step;


  list-style: none;


  padding: 0;


  margin: 20px 0;


}





.step-plan li {


  counter-increment: step;


  position: relative;


  padding: 20px 20px 20px 64px;


  margin-bottom: 16px;


  background: var(--card-bg);


  border: 1px solid var(--card-border);


  border-radius: var(--radius);


  backdrop-filter: blur(8px);


  -webkit-backdrop-filter: blur(8px);


  transition: all 0.3s ease;


}





.step-plan li:hover {


  background: var(--card-hover);


  border-color: rgba(255, 255, 255, 0.12);


}





.step-plan li::before {


  content: counter(step);


  position: absolute;


  left: 16px;


  top: 50%;


  transform: translateY(-50%);


  width: 32px;


  height: 32px;


  display: flex;


  align-items: center;


  justify-content: center;


  background: rgba(245, 158, 11, 0.12);


  border: 1px solid rgba(245, 158, 11, 0.25);


  border-radius: 50%;


  color: var(--color-gold);


  font-weight: 700;


  font-size: 0.9rem;


}





.step-plan li .step-title {


  color: var(--text-primary);


  font-weight: 600;


  font-size: 1rem;


  margin-bottom: 4px;


}





.step-plan li .step-desc {


  color: var(--text-muted);


  font-size: 0.9rem;


}





/* Affiliate Card */


.affiliate-card {


  background: linear-gradient(135deg, rgba(245, 158, 11, 0.06), rgba(16, 185, 129, 0.06));


  border: 1px solid rgba(245, 158, 11, 0.15);


  border-radius: var(--radius);


  padding: 24px;


  margin: 28px 0;


  backdrop-filter: blur(12px);


  -webkit-backdrop-filter: blur(12px);


}





.affiliate-card h4 {


  color: var(--color-gold);


  font-size: 1.1rem;


  margin-bottom: 8px;


}





.affiliate-card p {


  font-size: 0.9rem;


  margin-bottom: 12px;


}





.affiliate-card .price {


  display: inline-block;


  padding: 4px 12px;


  background: rgba(16, 185, 129, 0.1);


  border: 1px solid rgba(16, 185, 129, 0.2);


  border-radius: 50px;


  color: var(--crypto-green);


  font-weight: 600;


  font-size: 0.85rem;


}





.affiliate-btn {


  display: inline-block;


  padding: 10px 24px;


  background: linear-gradient(135deg, var(--color-gold), #d97706);


  color: #000;


  border-radius: var(--radius-sm);


  text-decoration: none;


  font-weight: 700;


  font-size: 0.9rem;


  border: none;


  cursor: pointer;


  transition: transform 0.2s, box-shadow 0.2s;


}





.affiliate-btn:hover {


  transform: translateY(-1px);


  box-shadow: 0 4px 16px rgba(245, 158, 11, 0.3);


  border-bottom: none;


  color: #000;


}





.affiliate-btn.green {


  background: linear-gradient(135deg, var(--crypto-green), var(--crypto-green-dim));


}





/* CTA Section */


.cta-section {


  background: linear-gradient(135deg, rgba(245, 158, 11, 0.08), rgba(16, 185, 129, 0.08));


  border: 1px solid rgba(245, 158, 11, 0.2);


  border-radius: var(--radius);


  padding: 32px;


  margin: 40px 0;


  text-align: center;


  backdrop-filter: blur(12px);


  -webkit-backdrop-filter: blur(12px);


  box-shadow: var(--glow-gold);


}





.cta-section h3 {


  font-size: 1.4rem;


  margin: 0 0 8px;


  color: var(--color-gold);


}





.cta-section p {


  color: var(--text-secondary);


  font-size: 0.95rem;


  margin: 0 0 20px;


  max-width: 500px;


  margin-left: auto;


  margin-right: auto;


}





.cta-btn {


  display: inline-block;


  padding: 14px 32px;


  background: linear-gradient(135deg, var(--color-gold), #d97706);


  color: #000;


  border-radius: var(--radius-sm);


  text-decoration: none;


  font-weight: 700;


  font-size: 1.05rem;


  border: none;


  cursor: pointer;


  transition: transform 0.2s, box-shadow 0.2s;


}





.cta-btn:hover {


  transform: translateY(-2px);


  box-shadow: 0 6px 20px rgba(245, 158, 11, 0.35);


  border-bottom: none;


  color: #000;


}





/* Inline Code */


code {


  background: rgba(255, 255, 255, 0.06);


  padding: 2px 8px;


  border-radius: 4px;


  font-size: 0.85rem;


  color: var(--crypto-green);


  font-family: 'JetBrains Mono', 'Fira Code', monospace;


}





/* Disclosure */


.disclosure {


  font-size: 0.8rem;


  color: var(--text-muted);


  margin: 32px 0;


  padding: 16px;


  background: var(--card-bg);


  border: 1px solid var(--card-border);


  border-radius: var(--radius-sm);


}





/* Footer */


.footer {


  margin-top: 60px;


  padding: 24px 0;


  border-top: 1px solid rgba(245, 158, 11, 0.1);


  text-align: center;


  color: var(--text-muted);


  font-size: 0.8rem;


  line-height: 2;


}





.footer a {


  color: var(--text-muted);


  font-size: 0.8rem;


}





.footer a:hover {


  color: var(--color-gold);


}





/* Divider */


hr {


  border: none;


  height: 1px;


  background: linear-gradient(90deg, transparent, rgba(245, 158, 11, 0.2), transparent);


  margin: 40px 0;


}





/* Responsive */


@media (max-width: 640px) {


  body { padding: 16px; }


  h1 { font-size: 1.6em; }


  h2 { font-size: 1.2em; }


  h3 { font-size: 1.05em; }


  p { font-size: 0.95rem; }


  .glass-card { padding: 16px; }


  .cta-section { padding: 24px 16px; }


  .step-plan li { padding: 16px 16px 16px 52px; }


  .step-plan li::before { left: 12px; width: 28px; height: 28px; font-size: 0.8rem; }


  table { font-size: 0.8rem; }


  thead th, tbody td { padding: 10px 12px; }


}





/* Scrollbar */


::-webkit-scrollbar { width: 8px; }


::-webkit-scrollbar-track { background: var(--bg-primary); }


::-webkit-scrollbar-thumb { background: rgba(245, 158, 11, 0.2); border-radius: 4px; }


::-webkit-scrollbar-thumb:hover { background: rgba(245, 158, 11, 0.4); }





/* TOC */


.toc { counter-reset: toc; }


.toc a { 


  display: block;


  padding: 8px 0;


  color: var(--text-secondary);


  border-bottom: 1px solid rgba(255, 255, 255, 0.04);


  transition: color 0.2s;


}


.toc a:hover { color: var(--color-gold); border-bottom-color: rgba(255, 255, 255, 0.04); }


.toc .toc-h2 { padding-left: 0; font-weight: 500; }


.toc .toc-h3 { padding-left: 20px; font-size: 0.9rem; }


