<!DOCTYPE html>
<html lang="en" class="theme-dogeking">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Contact Us - DogeKing</title>
  <meta property="og:title" content="Contact Us - DogeKing">
  <meta property="og:description" content="Get in touch with DogeKing. We">
  <meta property="og:image" content="https://dogeking.us/assets/crown-logo.svg">
  <meta property="og:url" content="https://dogeking.us/articles/contact.html">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Contact Us - DogeKing">
  <meta name="twitter:description" content="Get in touch with DogeKing. We">
  <meta name="twitter:image" content="https://dogeking.us/assets/crown-logo.svg">
<meta name="description" content="Get in touch with DogeKing. We'd love to hear from you.">
<link rel="canonical" href="https://dogeking.us/contact.html">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/crown-design-system.css">
<style>
.contact-section { max-width: 680px; margin: 120px auto 60px; padding: 0 20px; }
.contact-section h1 { font-size: 2rem; font-weight: 700; margin-bottom: 8px; }
.contact-section p { color: var(--text-secondary); margin-bottom: 32px; }
.contact-form { display: flex; flex-direction: column; gap: 16px; }
.contact-form label { font-weight: 500; font-size: 0.9rem; }
.contact-form input, .contact-form textarea { 
  padding: 12px 16px; border-radius: 10px; border: 1px solid var(--border);
  background: var(--bg-card); color: var(--text-primary); font-family: inherit;
  transition: border-color 0.2s;
}
.contact-form input:focus, .contact-form textarea:focus { outline: none; border-color: var(--primary); }
.contact-form button {
  padding: 14px 28px; background: var(--primary); color: #fff; border: none;
  border-radius: 10px; font-weight: 600; cursor: pointer; transition: all 0.3s;
}
.contact-form button:hover { transform: translateY(-2px); box-shadow: 0 8px 30px var(--primary-glow); }
</style>
  <link rel="stylesheet" href="/assets/brand.css">
<meta property="og:type" content="article">

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "contact",
  "url": "https://dogeking.us/contact",
  "publisher": { "@type": "Organization", "name": "DogeKing", "url": "https://dogeking.us" }
}
</script>
</head>
<body>
<header>
<nav>
  <div class="nav-container">
    <a href="/" class="nav-brand">�œ˜ DogeKing</a>
    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/all-articles.html">Articles</a>
      <a href="/store.html">Store</a>
    </div>
  </div>
</nav>
</header>
<div class="contact-section">
  <h1>Contact Us</h1>
  <p>Have a question, suggestion, or just want to say hello? We'd love to hear from you.</p>
  <form class="contact-form" action="https://formspree.io/f/your-form-id" method="POST">
    <label for="name">Your Name</label>
    <input type="text" id="name" name="name" placeholder="Enter your name" required>
    <label for="email">Your Email</label>
    <input type="email" id="email" name="email" placeholder="Enter your email" required>
    <label for="message">Message</label>
    <textarea id="message" name="message" rows="6" placeholder="How can we help you?" required></textarea>
    <button type="submit">Send Message</button>
  </form>
</div>
<footer>
  <div class="footer-container">
    <div class="footer-links">
      <a href="/">Home</a>
      <a href="/all-articles.html">Articles</a>
      <a href="/store.html">Store</a>
      <a href="/privacy-policy.html">Privacy</a>
      <a href="/terms-of-service.html">Terms</a>
    </div>
    <p class="footer-copy">&copy; 2026 DogeKing. All rights reserved.</p>
  </div>
</footer>
</body>
</html>