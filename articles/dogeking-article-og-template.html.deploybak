<h1>Template - Do Not Index</h1>

  <div class="grid-bg"></div><div class="accent-stripe"></div>
  <div class="corner-tl"></div><div class="corner-br"></div>
  <div class="glow-1"></div><div class="glow-2"></div>
  <div class="watermark">{{WATERMARK_SYMBOL}}</div>
  <div class="brand"><span class="brand-icon">{{BRAND_ICON}}</span><span class="brand-text">{{BRAND_NAME}}<span>{{BRAND_TAG}}</span></span></div>
  {{BADGE_HTML}}
  <div class="content-wrap">
    <div class="article-icon">{{ICON}}</div>
    <div class="tag">{{CATEGORY}}</div>
    <div class="main-title">Template - Do Not Index</div>
    This is a template file and should not be indexed.
    <div class="divider"></div>
    <div class="subtitle">{{SITE_TAGLINE}}</div>
  </div>
  <div class="url-bar">{{URL_BAR_PREFIX}}{{SITE_NAME}}{{URL_BAR_SUFFIX}}</div>
  {{DATE_HTML}}
