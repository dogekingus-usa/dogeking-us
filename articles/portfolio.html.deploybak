    <style>

        :root {

            --bg-primary: #0a0a1a;

            --bg-secondary: #111128;

            --bg-card: #1a1a3e;

            --color-gold: #FFD700;

            --color-gold-dark: #F0B90B;

            --color-gold-light: #FFE44D;

            --text-primary: #FFFFFF;

            --text-secondary: #B8B8D0;

            --text-muted: #8888AA;

            --accent-purple: #7C3AED;

            --accent-blue: #3B82F6;

            --danger: #EF4444;

            --success: #10B981;

            --border: #2a2a5a;

            --font-display: 'Playfair Display', serif;

            --font-body: 'Inter', sans-serif;

            --font-mono: 'JetBrains Mono', monospace;

        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body { background: var(--bg-primary); color: var(--text-primary); font-family: var(--font-body); line-height: 1.7; min-height: 100vh; }

        a { color: var(--color-gold); text-decoration: none; transition: color 0.2s; }

        a:hover { color: var(--color-gold-light); }

        h1, h2, h3, h4 { font-family: var(--font-display); font-weight: 700; line-height: 1.3; }

        h1 { font-size: 3rem; margin-bottom: 0.5rem; }

        h2 { font-size: 1.8rem; margin: 2.5rem 0 1rem; color: var(--color-gold); }

        p { margin-bottom: 1.2rem; color: var(--text-secondary); }



        nav { display: flex; align-items: center; justify-content: space-between; padding: 1rem 2rem; background: rgba(10,10,26,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 1000; }

        .nav-logo { font-family: var(--font-display); font-size: 1.5rem; color: var(--text-primary); text-decoration: none; }

        .nav-logo span { color: var(--color-gold); }

        .nav-links { display: flex; list-style: none; gap: 1.5rem; align-items: center; }

        .nav-links a { color: var(--text-secondary); font-size: 0.9rem; text-decoration: none; transition: color 0.2s; }

        .nav-links a:hover { color: var(--color-gold); }



        .hero { text-align: center; padding: 4rem 2rem 3rem; background: radial-gradient(ellipse at center, rgba(124,58,237,0.15) 0%, transparent 70%); }

        .hero h1 { background: linear-gradient(135deg, var(--color-gold), var(--accent-purple)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

        .hero .sub { color: var(--text-muted); font-size: 1.1rem; max-width: 600px; margin: 1rem auto; }



        .container { max-width: 900px; margin: 0 auto; padding: 0 1.5rem 3rem; }

        .quick-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin: 2rem 0; }

        .stat-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 1.25rem; text-align: center; }

        .stat-card .value { font-family: var(--font-display); font-size: 1.5rem; color: var(--accent-purple); font-weight: 900; }

        .stat-card .label { font-size: 0.8rem; color: var(--text-muted); margin-top: 0.25rem; }



        .article-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; margin-top: 1.5rem; }

        .article-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem; transition: all 0.2s; }

        .article-card:hover { border-color: var(--accent-purple); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(124,58,237,0.05); }

        .article-card .cat-badge { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: var(--accent-purple); margin-bottom: 0.5rem; }

        .article-card h3 { font-size: 1.1rem; margin-bottom: 0.5rem; }

        .article-card h3 a { color: var(--text-primary); }

        .article-card h3 a:hover { color: var(--color-gold); }

        .article-card p { font-size: 0.9rem; color: var(--text-muted); margin-bottom: 0.75rem; }

        .article-card .meta { font-size: 0.8rem; color: var(--text-muted); display: flex; gap: 1rem; }

        .article-card .read-more { font-size: 0.85rem; font-weight: 600; }



        .cta-section { background: linear-gradient(135deg, rgba(124,58,237,0.08), rgba(255,215,0,0.08)); border: 1px solid var(--accent-purple); border-radius: 16px; padding: 2.5rem; margin: 3rem 0; text-align: center; }

        .cta-section h2 { margin-top: 0; }

        .cta-section p { max-width: 500px; margin: 1rem auto; }

        .cta-btn { display: inline-block; background: linear-gradient(135deg, var(--accent-purple), var(--color-gold-dark)); color: var(--text-primary); padding: 0.85rem 2.5rem; border-radius: 8px; font-weight: 600; transition: transform 0.2s; }

        .cta-btn:hover { transform: translateY(-2px); color: var(--text-primary); }



        footer { text-align: center; padding: 2rem; border-top: 1px solid var(--border); margin-top: 3rem; color: var(--text-muted); font-size: 0.85rem; }

        footer a { color: var(--text-muted); }

        footer a:hover { color: var(--color-gold); }



        .cookie-banner { position: fixed; bottom: 0; left: 0; right: 0; background: var(--bg-secondary); border-top: 1px solid var(--border); padding: 1rem 2rem; display: none; justify-content: space-between; align-items: center; z-index: 9999; }

        @media (max-width: 768px) { h1 { font-size: 2rem; } .hero { padding: 2.5rem 1rem; } .article-grid { grid-template-columns: 1fr; } }

    </style>



