  <style>

    .checkout-hero {

      text-align: center;

      padding: 80px 20px 40px;

      background: var(--gradient-royal);

      position: relative;

    }

    .checkout-hero::before {

      content: '';

      position: absolute;

      inset: 0;

      background: radial-gradient(ellipse at center, rgba(255,215,0,0.06) 0%, transparent 70%);

    }

    .checkout-hero h1 {

      font-family: var(--font-heading);

      font-size: 2.2rem;

      font-weight: 800;

      color: var(--text-primary);

      margin-bottom: 8px;

    }

    .checkout-hero h1 .gold {

      background: var(--gradient-gold);

      -webkit-background-clip: text;

      -webkit-text-fill-color: transparent;

      background-clip: text;

    }

    .checkout-hero p {

      color: var(--text-muted);

      font-size: 1rem;

      max-width: 500px;

      margin: 0 auto;

    }

    .checkout-section {

      max-width: 700px;

      margin: 0 auto;

      padding: 40px 20px 60px;

    }

    .checkout-card {

      background: var(--surface-darkest);

      border: 1px solid rgba(255,215,0,0.1);

      border-radius: var(--radius-xl);

      padding: 40px;

      text-align: center;

    }

    .checkout-card .lock-icon {

      font-size: 3rem;

      margin-bottom: 16px;

    }

    .checkout-card h2 {

      font-family: var(--font-heading);

      font-size: 1.5rem;

      color: var(--color-gold);

      margin-bottom: 12px;

    }

    .checkout-card p {

      color: var(--text-muted);

      margin-bottom: 24px;

      line-height: 1.6;

    }

    .checkout-btn {

      display: inline-block;

      background: var(--gradient-gold);

      color: var(--surface-darkest);

      padding: 16px 40px;

      border-radius: var(--radius-lg);

      font-size: 1.1rem;

      font-weight: 700;

      text-decoration: none;

      transition: all var(--transition-normal);

      box-shadow: 0 4px 20px rgba(255,215,0,0.3);

    }

    .checkout-btn:hover {

      transform: translateY(-2px);

      box-shadow: 0 6px 30px rgba(255,215,0,0.5);

    }

    .secure-badge {

      display: flex;

      align-items: center;

      justify-content: center;

      gap: 8px;

      margin-top: 20px;

      color: var(--text-muted);

      font-size: 0.85rem;

    }

  </style>



